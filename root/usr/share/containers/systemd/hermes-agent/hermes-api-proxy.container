[Unit]
Description=hermes-agent API reverse proxy
After=hermes-agent.service

[Container]
Image=docker.io/library/caddy:2-alpine
GlobalArgs=--storage-opt=additionalimagestore=/usr/lib/bootc/storage
# Image is logically bound, so bootc keeps it in the additional store above;
# never pull into the primary store (avoids duplicate copies / orphaned records).
Pull=never
Pod=hermes-agent.pod
Environment=TZ=Pacific/Auckland
# Supplies API_SERVER_KEY, referenced as {env.API_SERVER_KEY} in the Caddyfile.
EnvironmentFile=/run/hermes-agent/api.env
Volume=/usr/share/containers/systemd/hermes-agent/Caddyfile:/etc/caddy/Caddyfile:ro

[Service]
Restart=always

[Install]
WantedBy=multi-user.target
