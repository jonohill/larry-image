[Unit]
Description=hermes-agent gateway
RequiresMountsFor=/var/mnt/data

[Container]
Image=docker.io/nousresearch/hermes-agent:v2026.6.19
GlobalArgs=--storage-opt=additionalimagestore=/usr/lib/bootc/storage
# Image is logically bound, so bootc keeps it in the additional store above;
# never pull into the primary store (avoids duplicate copies / orphaned records).
Pull=never
Pod=hermes-agent.pod
Environment=TZ=Pacific/Auckland
Environment=HERMES_UID=1000
Environment=HERMES_GID=1000
# Contains generated API key
EnvironmentFile=/run/hermes-agent/api.env
Volume=/mnt/data/hermes:/opt/data
# Image ENTRYPOINT is s6-overlay's /init; this is the command it supervises.
Exec=gateway run

[Service]
Restart=always
# Ensure the bind-mount source exists on the data volume before podman runs;
# RequiresMountsFor (above) guarantees /var/mnt/data is mounted first.
ExecStartPre=/usr/bin/mkdir -p /mnt/data/hermes

[Install]
WantedBy=multi-user.target
